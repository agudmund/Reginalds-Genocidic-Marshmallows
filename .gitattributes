# Normalize all text files to LF in the repo, native on checkout
* text=auto eol=lf
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.qss text eol=lf
*.json text eol=lf
*.intricate text eol=lf
# Binary — leave untouched
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.psd binary
# Video
*.mp4 binary
*.mov binary
*.mkv binary
*.avi binary
*.webm binary
*.wmv binary
*.flv binary
*.m4v binary
# Audio
*.wav binary
*.mp3 binary
*.flac binary
*.ogg binary
*.m4a binary
*.aac binary
*.wma binary
# 3D / other media
*.fbx binary
*.exr binary
*.tif binary
*.tiff binary
*.pyd binary
# Large executables tracked via LFS when present
*.exe filter=lfs diff=lfs merge=lfs -text
